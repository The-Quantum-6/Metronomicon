DATABASE_URL=postgresql://postgres:postgres@localhost:5432/db
# Signals to the backend to turn off CORS
ENVIRONMENT=dev

# --- Garage / S3 object storage ---
# Running the backend on the host (cargo run / cargo run --example garage_smoke),
# Garage is reachable on localhost. Inside docker compose use http://garage:3900.
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=test-bucket
# From `garage key create` -- paste the Key ID and Secret. Never commit real keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
